{
  "schemaVersion": 1,
  "id": "glacierclient",
  "version": "${version}",
  "name": "Glacier Client",
  "description": "A feature-rich Fabric client mod for Minecraft 1.20.4",
  "authors": [
    "GlacierClient Team"
  ],
  "contact": {
    "homepage": "https://glacierclient.net",
    "sources": "https://github.com/pepeongithub/glacier-client-java-test"
  },
  "license": "MIT",
  "icon": "assets/glacierclient/icon.png",
  "environment": "client",
  "entrypoints": {
    "client": [
      "net.glacierclient.GlacierClient"
    ]
  },
  "mixins": [
    "mixins.glacierclient.json"
  ],
  "depends": {
    "fabricloader": ">=0.15.7",
    "fabric-api": "*",
    "minecraft": "~1.20.4",
    "java": ">=17"
  }
}
